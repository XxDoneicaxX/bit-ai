# Comma-separated list of origins allowed to call this API (your frontend's URL)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Where Ollama is running. If Ollama runs on the same EC2 instance as this
# backend, localhost is correct. If it's on a separate box, point this at it.
OLLAMA_URL=http://localhost:11434/api/chat

# The model tag Ollama should use (must already be pulled on that machine)
OLLAMA_MODEL=gemma4:e4b
